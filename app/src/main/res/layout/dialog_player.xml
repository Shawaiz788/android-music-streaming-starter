<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A67B5B"
    android:padding="24dp">

    <View
        android:id="@+id/top_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:background="#80FFFFFF" />

    <TextView
        android:id="@+id/tv_top_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_handle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:text="Play Now: Playlist «Mysterious»"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/iv_song"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_above="@id/fav_btn"
        android:layout_centerHorizontal="true"
        android:scaleType="centerCrop"
        android:elevation="8dp"
        android:background="@drawable/rounded_button"
        />
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="30dp"
        android:layout_centerHorizontal="true"
        android:id="@+id/fav_btn"
        android:layout_above="@id/tv_title"
        android:layout_margin="8dp"
        app:cardBackgroundColor="#40FFFFFF"
        >
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_fav"
            android:padding="6dp"
            />

    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_music_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="Music List"
        android:textAllCaps="false"
        android:textColor="@android:color/black"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="20dp"
        app:icon="@android:drawable/arrow_up_float"
        app:iconGravity="end"
        app:iconTint="@android:color/black" />

    <RelativeLayout
        android:id="@+id/layout_timers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btn_music_list"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/tv_current_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="0:36"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="2:43"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />
    </RelativeLayout>

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/layout_timers"
        android:layout_marginBottom="8dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:progress="25"
        android:progressBackgroundTint="#4DFFFFFF"
        android:progressTint="@android:color/white"
        android:thumbTint="@android:color/white" />

    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/seek_bar"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_sort_alphabetically"
            app:tint="#E6FFFFFF" />

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@android:color/white" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_pause"
                app:tint="@android:color/black"
                android:id="@+id/iv_play_pause"/>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_next"
            app:tint="@android:color/white" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_more"
            app:tint="#E6FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/layout_controls"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        android:text="Podval Caplella"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/tv_artist"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="4dp"
        android:text="Burning"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold" />

</RelativeLayout>