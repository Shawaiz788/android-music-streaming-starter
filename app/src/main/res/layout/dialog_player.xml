<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A67B5B">

    <!-- Fading Player Elements -->
    <RelativeLayout
        android:id="@+id/player_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="25dp">

        <!-- Top Status -->
        <TextView
            android:id="@+id/tv_top_status_internal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Play Now: Playlist «Mysterious»"
            android:textColor="@android:color/white"
            android:textSize="15sp" />

        <!-- Music List Button (Bottom) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_music_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="20dp"
            android:text="Music List"
            android:textAllCaps="false"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/arrow_up_float"
            app:iconGravity="end"
            app:iconTint="@android:color/black" />

        <!-- Bottom Controls and Seek Section -->
        <LinearLayout
            android:id="@+id/layout_controls_and_seek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/btn_music_list"
            android:layout_marginBottom="20dp"
            android:orientation="vertical">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="25"
                android:progressBackgroundTint="#4DFFFFFF"
                android:progressTint="@android:color/white"
                android:thumbTint="@android:color/white" />

            <RelativeLayout
                android:id="@+id/layout_timers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="0:36"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="2:43"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/layout_controls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/equalizer"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:scaleType="centerInside"
                    android:src="@drawable/icon_equaliser"
                    app:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/btn_prev"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@android:color/white" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_play_pause"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_marginHorizontal="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_play_pause"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_media_pause"
                        app:tint="@android:color/black" />
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/btn_next"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@android:color/white" />

                <ImageView
                    android:id="@+id/menu_more"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    android:scaleType="centerInside"
                    android:src="@drawable/icon_options"
                    app:tint="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- Center Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_top_status_internal"
            android:layout_above="@id/layout_controls_and_seek"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_song"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_button"
                android:elevation="0dp"
                android:scaleType="centerCrop" />

            <androidx.cardview.widget.CardView
                android:id="@+id/fav_btn"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#40FFFFFF"
                app:cardCornerRadius="25dp"
                app:cardElevation="10dp">

                <ImageView
                    android:id="@+id/iv_fav"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_fav"
                    app:tint="@android:color/white" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:text="Burning"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="Podval Caplella"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Bottom Sheets -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/more_menu_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <include layout="@layout/layout_player_more_menu" />
    </androidx.core.widget.NestedScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/equalizer_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <include layout="@layout/dialog_equalizer" />
    </androidx.core.widget.NestedScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/lyrics_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        <include layout="@layout/dialog_lyrics" />
    </androidx.core.widget.NestedScrollView>

    <!-- Persistent Header Handle -->
    <View
        android:id="@+id/top_handle"
        android:layout_width="45dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="15dp"
        android:background="@android:color/white"
        android:elevation="12dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>