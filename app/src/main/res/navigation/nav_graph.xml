<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.musicplayer.HomeFragment" />

    <fragment
        android:id="@+id/topFragment"
        android:name="com.example.musicplayer.TopMusicFragment" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.musicplayer.FavoritesFragment" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.musicplayer.SearchFragment">
        <argument
            android:name="initialQuery"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.musicplayer.ProfileFragment" />

    <fragment
        android:id="@+id/ReleasesFragment"
        android:name="com.example.musicplayer.ReleasesFragment" />
    <fragment
        android:id="@+id/downloadsFragment"
        android:name="com.example.musicplayer.DownloadsFragment" />
    <fragment
        android:id="@+id/FavouriteAlbumsFragment"
        android:name="com.example.musicplayer.FavouriteAlbumsFragment" />
    <fragment
        android:id="@+id/favouriteTracksFragment"
        android:name="com.example.musicplayer.FavouriteTracksFragment" />
    <fragment
        android:id="@+id/favouritePlaylistFragment"
        android:name="com.example.musicplayer.FavouritePlaylistFragment" />
    <fragment
        android:id="@+id/fragment_music_recognition"
        android:name="com.example.musicplayer.MusicRecognitionFragment" />

    <fragment
        android:id="@+id/albumDetailsFragment"
        android:name="com.example.musicplayer.AlbumDetailsFragment">
        <argument
            android:name="album"
            app:argType="com.example.musicplayer.Album" />
    </fragment>

    <fragment
        android:id="@+id/playlistDetailsFragment"
        android:name="com.example.musicplayer.PlaylistDetailsFragment">
        <argument
            android:name="playlist"
            app:argType="com.example.musicplayer.Playlist" />
    </fragment>
</navigation>